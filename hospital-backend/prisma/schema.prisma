generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Utilisateur {
  id            Int             @id @default(autoincrement())
  nom           String
  prenom        String
  email         String          @unique
  motDePasse    String
  role          RoleUtilisateur
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  admin         Admin?
  medecin       Medecin?
  notifications Notification[]
  patient       Patient?
  sousAdmin     SousAdmin?
}

model Patient {
  id             Int             @id @default(autoincrement())
  utilisateurId  Int             @unique
  telephone      String?
  dossierMedical DossierMedical?
  feedbacks      Feedback[]
  utilisateur    Utilisateur     @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  ordonnances    Ordonnance[]
  rendezVous     RendezVous[]
  salleAttente   SalleAttente[]
  urgences       Urgence[]
}

model Medecin {
  id                           Int          @id @default(autoincrement())
  utilisateurId                Int          @unique
  specialite                   String?
  phone                        String?
  address                      String?
  licenseNumber                String?
  signingPublicKeySpkiBase64   String?
  conges                       Conge[]
  utilisateur                  Utilisateur  @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  ordonnances                  Ordonnance[]
  rendezVous                   RendezVous[]
  sealedDocuments              Document[]
}

model Admin {
  id            Int         @id @default(autoincrement())
  utilisateurId Int         @unique
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

model SousAdmin {
  id              Int            @id @default(autoincrement())
  utilisateurId   Int            @unique
  specialite      String?
  phone           String?
  status          String?        @default("actif")
  permissions     String[]
  rendezVousGeres RendezVous[]
  salleAttente    SalleAttente[]
  utilisateur     Utilisateur    @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

model DossierMedical {
  id                      Int        @id @default(autoincrement())
  patientId               Int        @unique
  dateNaissance           String?
  groupeSanguin           String?
  numSecuriteSociale      String?
  allergies               String[]
  historiqueMedical       String[]
  contactUrgenceNom       String?
  contactUrgenceRelation  String?
  contactUrgenceTelephone String?
  contactUrgenceEmail     String?
  documents               Document[]
  patient                 Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Document {
  id                      Int            @id @default(autoincrement())
  titre                   String
  urlFichier              String
  type                    String?
  praticien               String?
  createdAt               DateTime       @default(now())
  dossierMedicalId        Int
  dossierMedical          DossierMedical @relation(fields: [dossierMedicalId], references: [id], onDelete: Cascade)
  medecinId               Int?
  medecin                 Medecin?       @relation(fields: [medecinId], references: [id], onDelete: SetNull)
  publicId                String?        @unique
  contentSha256           String?
  signatureBase64         String?
  signingKeySpkiSnapshot  String?
  cipherStoragePath       String?
  aesIvBase64             String?
  aesAuthTagBase64        String?
  anchorTxHash            String?
  anchorChainId           Int?
  anchorContractAddress   String?
  anchorBlockNumber       BigInt?
  anchoredAt              DateTime?
  /// Texte du compte rendu (aperçu) pour les PDF sécurisés générés côté serveur ; le fichier officiel reste le PDF chiffré.
  securePreviewSummary    String?
}

model Ordonnance {
  id        Int      @id @default(autoincrement())
  contenu   String
  urlPdf    String?
  createdAt DateTime @default(now())
  patientId Int
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medecinId Int
  medecin   Medecin  @relation(fields: [medecinId], references: [id], onDelete: Cascade)
}

model RendezVous {
  id          Int        @id @default(autoincrement())
  date        DateTime
  motif       String?
  specialite  String?
  statut      StatutRDV  @default(EN_ATTENTE)
  lieu        String?    @default("À définir")
  salle       String?    @default("À définir")
  patientId   Int
  medecinId   Int?
  sousAdminId Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  medecin     Medecin?   @relation(fields: [medecinId], references: [id], onDelete: Cascade)
  patient     Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sousAdmin   SousAdmin? @relation(fields: [sousAdminId], references: [id])
}

model SalleAttente {
  id             Int            @id @default(autoincrement())
  sousAdminId    Int
  patientId      Int
  joinedAt       DateTime       @default(now())
  status         String         @default("EN_ATTENTE")
  isUrgent       Boolean        @default(false)
  presenceStatus PresenceStatus @default(PREVU)
  patient        Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  sousAdmin      SousAdmin      @relation(fields: [sousAdminId], references: [id], onDelete: Cascade)
}

model Notification {
  id            Int         @id @default(autoincrement())
  titre         String
  message       String
  lue           Boolean     @default(false)
  createdAt     DateTime    @default(now())
  utilisateurId Int
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

model Urgence {
  id          Int           @id @default(autoincrement())
  typeUrgence String
  statut      StatutUrgence @default(EN_COURS)
  date        DateTime      @default(now())
  patientId   Int
  patient     Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Feedback {
  id          Int      @id @default(autoincrement())
  note        Int
  commentaire String?
  createdAt   DateTime @default(now())
  patientId   Int
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Conge {
  id        Int      @id @default(autoincrement())
  medecinId Int
  startDate DateTime
  endDate   DateTime
  reason    String?
  medecin   Medecin  @relation(fields: [medecinId], references: [id], onDelete: Cascade)
}

model LieuInteret {
  id          Int      @id @default(autoincrement())
  nom         String
  etage       Int
  batiment    String
  description String?
  icon        String?
  color       String?
  bgColor     String?
  type        String   @default("DEPARTMENT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum RoleUtilisateur {
  PATIENT
  MEDECIN
  ADMIN
  SOUS_ADMIN
}

enum StatutRDV {
  EN_ATTENTE
  CONFIRME
  ANNULE
  REPORTE
  EN_COURS
  TERMINE
}

enum StatutUrgence {
  EN_COURS
  RESOLUE
}

enum PresenceStatus {
  PREVU
  PRESENT
  EN_RETARD
  ANNULE
  ABSENT
}
