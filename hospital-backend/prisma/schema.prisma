datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleUtilisateur {
  PATIENT
  MEDECIN
  ADMIN
  SOUS_ADMIN
}

enum StatutRDV {
  EN_ATTENTE
  CONFIRME
  ANNULE
  REPORTE
}

enum StatutUrgence {
  EN_COURS
  RESOLUE
}

enum PresenceStatus {
  PREVU
  PRESENT
  EN_RETARD
  ANNULE
  ABSENT
}

// ─── CLASSE ABSTRAITE (Mappée via Relation 1-1) ────────────────────────────────

model Utilisateur {
  id         Int             @id @default(autoincrement())
  nom        String
  prenom     String
  email      String          @unique
  motDePasse String
  role       RoleUtilisateur
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  // Relations "héritées"
  patient   Patient?
  medecin   Medecin?
  admin     Admin?
  sousAdmin SousAdmin?

  // L'utilisateur peut recevoir des notifications
  notifications Notification[]
}

// ─── CLASSES HERITEES ────────────────────────────────────────────────────────

model Patient {
  id            Int         @id @default(autoincrement())
  utilisateurId Int         @unique
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  telephone     String?

  // Relations
  rendezVous     RendezVous[]
  dossierMedical DossierMedical? // Relation 1-1 au Dossier Medical
  urgences       Urgence[]
  feedbacks      Feedback[]
  salleAttente   SalleAttente[]
}

model Medecin {
  id            Int         @id @default(autoincrement())
  utilisateurId Int         @unique
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  specialite    String?

  rendezVous  RendezVous[]
  conges      Conge[]
  ordonnances Ordonnance[]
}

model Admin {
  id            Int         @id @default(autoincrement())
  utilisateurId Int         @unique
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

model SousAdmin {
  id            Int         @id @default(autoincrement())
  utilisateurId Int         @unique
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  specialite    String?     // Added: to notify based on department (e.g., Cardiology)

  // Un SousAdmin gère ses propres rendez-vous assignés et une salle d'attente
  rendezVousGeres RendezVous[]
  salleAttente    SalleAttente[]
}

// ─── CLASSES METIER ─────────────────────────────────────────────────────────

model DossierMedical {
  id                      Int      @id @default(autoincrement())
  patientId               Int      @unique
  patient                 Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  dateNaissance           String?
  groupeSanguin           String?
  numSecuriteSociale      String?
  allergies               String[]
  historiqueMedical       String[]
  contactUrgenceNom       String?
  contactUrgenceRelation  String?
  contactUrgenceTelephone String?

  documents Document[]
}

model Document {
  id         Int      @id @default(autoincrement())
  titre      String
  urlFichier String
  type       String?
  createdAt  DateTime @default(now())

  dossierMedicalId Int
  dossierMedical   DossierMedical @relation(fields: [dossierMedicalId], references: [id], onDelete: Cascade)
}

model Ordonnance {
  id        Int      @id @default(autoincrement())
  contenu   String
  urlPdf    String?
  createdAt DateTime @default(now())

  // Une ordonnance relie un médecin à un patient (soit via patient direct, soit via dossier_medical, ici direct médecin->ordonnance)
  medecinId Int
  medecin   Medecin @relation(fields: [medecinId], references: [id], onDelete: Cascade)

  // Une ordonnance peut être traitée comme un Document (polymorphisme simple simulé)
  // Ou on la lie simplement au patient
}

model RendezVous {
  id             Int            @id @default(autoincrement())
  date           DateTime
  motif          String?
  specialite     String?
  statut         StatutRDV      @default(EN_ATTENTE)
  isUrgent       Boolean        @default(false)
  presenceStatus PresenceStatus @default(PREVU)
  lieu           String?        @default("À définir")
  salle          String?        @default("À définir")

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  medecinId Int?
  medecin   Medecin? @relation(fields: [medecinId], references: [id], onDelete: Cascade)

  sousAdminId Int?
  sousAdmin   SousAdmin? @relation(fields: [sousAdminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SalleAttente {
  id          Int       @id @default(autoincrement())
  sousAdminId Int
  sousAdmin   SousAdmin @relation(fields: [sousAdminId], references: [id], onDelete: Cascade)
  patientId   Int
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())
  status      String    @default("EN_ATTENTE") // EN_ATTENTE, EN_CONSULTATION
}

model Notification {
  id        Int      @id @default(autoincrement())
  titre     String
  message   String
  lue       Boolean  @default(false)
  createdAt DateTime @default(now())

  utilisateurId Int
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
}

// ─── AUTRES ENTITES SECONDAIRES ──────────────────────────────────────────────

model Urgence {
  id          Int           @id @default(autoincrement())
  typeUrgence String
  statut      StatutUrgence @default(EN_COURS)
  date        DateTime      @default(now())

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Feedback {
  id          Int      @id @default(autoincrement())
  note        Int
  commentaire String?
  createdAt   DateTime @default(now())

  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Conge {
  id        Int      @id @default(autoincrement())
  medecinId Int
  medecin   Medecin  @relation(fields: [medecinId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime
  reason    String?
}

model LieuInteret {
  id          Int      @id @default(autoincrement())
  nom         String
  etage       Int
  batiment    String
  description String?
  icon        String?
  color       String?
  bgColor     String?
  type        String   @default("DEPARTMENT") // DEPARTMENT, EQUIPMENT
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
