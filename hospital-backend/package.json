{
    "name": "hospital-backend",
    "version": "1.0.0",
    "description": "Hospital Backend API",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "nodemon --exec ts-node --transpile-only src/index.ts",
        "build": "tsc",
        "seed": "ts-node --transpile-only prisma/seed.ts",
        "create-sa": "ts-node src/utils/create-sa.ts",
        "db:migrate": "prisma migrate dev",
        "db:push": "prisma db push",
        "db:pull": "prisma db pull",
        "db:sync": "prisma db pull && prisma generate",
        "db:studio": "prisma studio",
        "db:generate": "prisma generate"
    },
    "prisma": {
        "seed": "ts-node --transpile-only prisma/seed.ts"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "@types/nodemailer": "^8.0.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^5.0.1",
        "jsonwebtoken": "^9.0.2",
        "nodemailer": "^8.0.4",
        "pg": "^8.13.1"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^22.0.0",
        "nodemon": "^3.1.9",
        "prisma": "^5.22.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.0"
    }
}