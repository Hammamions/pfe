# Copier ce fichier vers .env puis remplir les valeurs réelles.
# PowerShell:  Copy-Item .env.example .env
# CMD:         copy .env.example .env

# Base PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# JWT pour les sessions API + jetons de vérification document
JWT_SECRET="changez_moi_secret_long_et_unique"

# Optionnel : URL publique du backend (emails, liens)
# BACKEND_PUBLIC_URL="http://localhost:4000"

# Chiffrement des PDF sécurisés (obligatoire pour « Envoyer au patient » / seal)
# Soit 64 caractères hexadécimaux, soit une phrase d’au moins 8 caractères.
SECURE_DOCS_STORAGE_KEY="remplacez_par_une_cle_secrete_longue"

# SMTP (optionnel, selon les fonctionnalités mail)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# Ancrage blockchain (optionnel — sinon les documents restent chiffrés sans ancrage)
# ANCHOR_RPC_URL=http://127.0.0.1:8545
# ANCHOR_PRIVATE_KEY=0x...
# ANCHOR_CONTRACT_ADDRESS=0x...
# ANCHOR_CHAIN_ID=31337

# Durée du JWT de vérification document (défaut 7d)
# DOC_VERIFY_JWT_EXPIRES=7d

# Port HTTP du serveur (défaut 4000)
# PORT=4000
