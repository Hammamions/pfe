{
    "name": "hospital-backend",
    "version": "1.0.0",
    "description": "Hospital Backend API",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "nodemon --exec ts-node --transpile-only src/index.ts",
        "build": "tsc",
        "seed": "ts-node --transpile-only prisma/seed.ts",
        "create-sa": "ts-node src/utils/create-sa.ts",
        "create-admin": "ts-node --transpile-only src/utils/create-admin.ts",
        "seed:today-rdv-test": "ts-node --transpile-only src/utils/create-today-test-appointments.ts",
        "seed:reclamation-rdv-test": "ts-node --transpile-only src/utils/create-reclamation-test-appointments.ts",
        "db:migrate": "prisma migrate dev",
        "db:push": "prisma db push",
        "db:pull": "prisma db pull",
        "db:sync": "prisma db pull && prisma generate",
        "db:studio": "prisma studio",
        "db:generate": "prisma generate",
        "compile:anchor": "hardhat compile",
        "deploy:anchor-amoy": "hardhat run scripts/deploy-anchor.cjs --network polygonAmoy",
        "deploy:anchor-local": "hardhat run scripts/deploy-anchor-local.cjs --network localhost",
        "anchor:bootstrap-wallet": "node scripts/ensure-anchor-wallet.cjs"
    },
    "prisma": {
        "seed": "ts-node --transpile-only prisma/seed.ts"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "@types/nodemailer": "^8.0.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "ethers": "^6.16.0",
        "express": "^5.0.1",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.1",
        "nodemailer": "^8.0.4",
        "pdf-lib": "^1.17.1",
        "pg": "^8.13.1",
        "qrcode": "^1.5.4"
    },
    "devDependencies": {
        "@nomicfoundation/hardhat-toolbox": "^5.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/multer": "^2.1.0",
        "@types/node": "^22.0.0",
        "@types/qrcode": "^1.5.6",
        "hardhat": "^2.22.18",
        "nodemon": "^3.1.9",
        "prisma": "^5.22.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.0"
    }
}
